    {
      "name": "Identity",
      "item": [
        {
          "name": "Get current user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var mode = (pm.environment.get(\"contractExecutionMode\") || \"live\").toLowerCase();",
                  "var token = pm.variables.replaceIn(\"{{developerAccessToken}}\");",
                  "var hasConfiguredToken = Boolean(token && token.indexOf(\"{{\") !== 0 && token.indexOf(\"replace-with-\") !== 0);",
                  "if (mode !== \"mock\" && !hasConfiguredToken) {",
                  "  pm.test(\"Current user request returns auth failure without configured token\", function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "  return;",
                  "}",
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test(\"Current user subject returned\", function () { pm.expect(json.subject).to.be.a(\"string\").and.to.not.eql(\"\"); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{developerAccessToken}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/identity/me", "host": ["{{baseUrl}}"], "path": ["identity", "me"] }
